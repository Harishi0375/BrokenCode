[node name="TriggerOnEntry" parent="." unique_id=239071959 instance=ExtResource("5_trig")]
position = Vector2(80, 60)
dialogue_lines = Array[String](["[P] — Okay. This one I left because it was 'too generic.' It's fine. It's gonna be fine. Easy even.", "[P] — ...It's not generic. It's a nightmare. I built an actual nightmare."])

[node name="TriggerControls" parent="." unique_id=1927880256 instance=ExtResource("5_trig")]
position = Vector2(120, 60)
dialogue_lines = Array[String](["[P] — Wait. WAIT. Arrow keys? I switched to arrow keys for this one? The first game used WASD — why would I change that? Just stick to one thing! Why do I always try to be so unique every single time?!"])

[node name="TriggerEnemies" parent="." unique_id=445208563 instance=ExtResource("5_trig")]
position = Vector2(-20, -10)
dialogue_lines = Array[String](["[P] — Okay so they're spawning from empty tiles instead of actual spawn points. Classic. Truly classic work from me.", "[P] — On the bright side at least I can predict where they WON'T spawn."])

[node name="TriggerLost" parent="." unique_id=1561081385 instance=ExtResource("5_trig")]
position = Vector2(0, 50)
dialogue_lines = Array[String](["[P] — This map is SO huge. I designed this map. I have no idea where I am.", "[P] — Lowkey... the first game wasn't that bad. Like it was simple but at least I knew where I was going. Why did I even start this one."])

[node name="TriggerNearExit" parent="." unique_id=1764902540 instance=ExtResource("5_trig")]
position = Vector2(200, 50)
dialogue_lines = Array[String](["[P] — Please maze end. Please. I cannot postpone the game jam deadline. I cannot explain this to anyone."])

[node name="TriggerCompletion" parent="." unique_id=1224006253 instance=ExtResource("5_trig")]
position = Vector2(250, 50)
dialogue_lines = Array[String](["[N] — That took you embarrassingly long. But okay — congrats. I genuinely didn't think you'd make it out of there.", "[P] — Neither did I."])
